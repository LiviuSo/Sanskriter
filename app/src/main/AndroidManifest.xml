<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.android.lvicto.sanskriter">

    <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />

    <application
        android:name=".MyApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/AppTheme">

        <activity android:name=".ui.activities.TextsActivity"/>

        <activity android:name=".ui.activities.PronounsActivity" />

        <activity android:name=".ui.activities.VerbsActivity" />

        <activity
            android:name=".ui.activities.DeclensionActivity"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar"/>

        <uses-library
            android:name="com.android.lvicto.dictionary"
            android:required="false" />

        <activity
            android:name=".ui.activities.PagesActivity"
            android:screenOrientation="portrait"
            android:theme="@style/AppTheme.BookTheme" />

        <activity
            android:name=".ui.activities.SetupActivity"
            android:screenOrientation="portrait">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.activities.MainActivity" />

        <activity
            android:name=".ui.activities.KeyboardSelectPopupActivity"
            android:theme="@style/AppTheme.CustomTheme" />

        <activity android:name=".ui.activities.TestKeyboardActivity" />

        <activity android:name=".ui.activities.BookActivity" />
    </application>

</manifest>