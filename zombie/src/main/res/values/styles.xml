<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="KeyStyle">
        <item name="android:layout_marginStart">3dp</item>
        <item name="android:layout_marginLeft">3dp</item>
        <item name="android:layout_marginTop">3dp</item>
        <item name="android:gravity">center</item>
        <item name="android:padding">10dp</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="KeyStyleRight" parent="KeyStyle">
        <item name="android:layout_marginEnd">3dp</item>
        <item name="android:layout_marginRight">3dp</item>
    </style>

    <style name="KeyStyleBottom" parent="KeyStyle">
        <item name="android:layout_marginBottom">3dp</item>
    </style>

    <style name="KeyStyleRightBottom" parent="KeyStyle">
        <item name="android:layout_marginEnd">3dp</item>
        <item name="android:layout_marginRight">3dp</item>
        <item name="android:layout_marginBottom">3dp</item>
    </style>
</resources>
